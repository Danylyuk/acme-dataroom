# ── Порт бекенду
PORT=8787

# ── JWT — секрет для підпису сесійних токенів (будь-який довгий рядок)
JWT_SECRET=change-me-to-a-long-random-string

# ── Resend (лист із кодом підтвердження). Без ключа код друкується в консоль (dev).
RESEND_API_KEY=
# Від кого надсилати (має бути верифікований домен у Resend)
MAIL_FROM=Acme Corp. Data Room <noreply@acmecorp.deepcloud.space>

# ── Cloudflare Turnstile (захист від ботів). Секретний ключ з дашборду Turnstile.
# Для локальної розробки можна лишити тестовий секрет, що завжди пропускає:
TURNSTILE_SECRET=1x0000000000000000000000000000000AA

# ── CORS: домен фронтенду (кома-розділений список)
CORS_ORIGIN=http://localhost:3000,https://acmecorp.deepcloud.space
